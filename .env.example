# Copy to `.env` and adjust. These are read by the Python analysis service.

# --- LLM (Gen-AI synthesis & chat) ---
# Lumina is bring-your-own-key. The preferred way to configure providers
# (OpenAI, Google Gemini, OpenRouter, or a custom OpenAI-compatible endpoint)
# is the in-app onboarding / Settings page — those are stored in
# ~/.lumina/config.json and can be changed anytime.
#
# The vars below are only an OPTIONAL fallback used to SEED the OpenAI provider
# on first launch when no config.json exists yet. Leave blank to configure
# everything from the UI. With no key anywhere, a deterministic heuristic
# synthesis is used so the pipeline still runs (chat, however, needs a key).
LUMINA_LLM_API_KEY=
LUMINA_LLM_BASE_URL=https://api.openai.com/v1
LUMINA_LLM_MODEL=gpt-4o-mini

# --- Tooling paths ---
# Path to the jadx CLI (jadx / jadx.bat). If not on PATH, decompilation is skipped.
LUMINA_JADX_PATH=jadx

# --- Dynamic analysis ---
# Set to 1 to attempt real Frida instrumentation (needs frida-server on an
# emulator + the target installed via adb). Otherwise a simulated trace is used.
LUMINA_FRIDA=0

# --- Workspace (ingested APKs, decompiled sources, reports) ---
# Defaults to ~/.lumina/workspace
# LUMINA_WORKSPACE=
