# Copy to `.env` and adjust. These are read by the Python analysis service.

# --- LLM (Gen-AI synthesis) — any OpenAI-compatible endpoint ---
# Leave the API key blank to use the built-in deterministic heuristic synthesis.
LUMINA_LLM_API_KEY=
LUMINA_LLM_BASE_URL=https://api.openai.com/v1
LUMINA_LLM_MODEL=gpt-4o-mini

# --- Tooling paths ---
# Path to the jadx CLI (jadx / jadx.bat). If not on PATH, decompilation is skipped.
LUMINA_JADX_PATH=jadx

# --- Dynamic analysis ---
# Set to 1 to attempt real Frida instrumentation (needs frida-server on an
# emulator + the target installed via adb). Otherwise a simulated trace is used.
LUMINA_FRIDA=0

# --- Workspace (ingested APKs, decompiled sources, reports) ---
# Defaults to ~/.lumina/workspace
# LUMINA_WORKSPACE=
